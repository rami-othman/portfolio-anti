---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import skillsData from '../content/skills.json';

const { aiml, data, tools, cloud } = skillsData;
---

<BaseLayout title="About Rami | AI & Data Engineer">
  <Header slot="header" />
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 w-full py-16 flex-grow">
    
    <div class="mb-12 animate-fade-in-up">
      <h1 class="text-3xl sm:text-4xl font-bold text-text-main mb-6 tracking-tight">About Me</h1>
      
      <div class="prose prose-invert max-w-none text-text-muted text-lg leading-relaxed">
        <p>
          I'm an engineer who loves bridging the gap between cutting-edge AI research and robust, scalable production systems. 
          My background in both Machine Learning and Data Engineering allows me to see the full lifecycle of a model—from 
          messy raw data ingestion, through training and optimization, all the way to a highly available inference endpoint.
        </p>
        <p>
          Currently, my focus is on <strong class="text-primary-400 font-medium">Retrieval-Augmented Generation (RAG)</strong> architectures 
          and deploying <strong class="text-secondary-400 font-medium">local Large Language Models</strong> efficiently on edge or cost-constrained hardware.
        </p>
        <p>
          When I'm not tweaking ONNX graphs or writing Spark streaming jobs, I enjoy contributing to open-source tooling around LLM evaluations.
        </p>
      </div>
    </div>

    <hr class="border-border my-12" />

    <div class="animate-fade-in-up" style="animation-delay: 0.1s;">
      <h2 class="text-2xl font-bold text-text-main mb-8">Technical Arsenal</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        {/* AI/ML */}
        <div class="bg-surface-elevated p-6 rounded-xl border border-border">
          <h3 class="text-primary-400 font-semibold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m4.93 10.93 14.14 14.14"/><path d="m2 12 20 20"/><path d="m4.93 19.07 14.14-14.14"/></svg>
            AI & Machine Learning
          </h3>
          <ul class="flex flex-wrap gap-2">
            {aiml.map((skill) => (
              <li class="bg-surface px-3 py-1.5 rounded-md text-sm text-text-main border border-border">{skill}</li>
            ))}
          </ul>
        </div>

        {/* Data Engineering */}
        <div class="bg-surface-elevated p-6 rounded-xl border border-border">
          <h3 class="text-secondary-400 font-semibold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
            Data Engineering
          </h3>
          <ul class="flex flex-wrap gap-2">
            {data.map((skill) => (
              <li class="bg-surface px-3 py-1.5 rounded-md text-sm text-text-main border border-border">{skill}</li>
            ))}
          </ul>
        </div>

        {/* Tools */}
        <div class="bg-surface-elevated p-6 rounded-xl border border-border">
          <h3 class="text-text-main font-semibold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Development & Tools
          </h3>
          <ul class="flex flex-wrap gap-2">
            {tools.map((skill) => (
              <li class="bg-surface px-3 py-1.5 rounded-md text-sm text-text-main border border-border">{skill}</li>
            ))}
          </ul>
        </div>

        {/* Cloud */}
        <div class="bg-surface-elevated p-6 rounded-xl border border-border">
          <h3 class="text-text-main font-semibold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
            Cloud & Deployment
          </h3>
          <ul class="flex flex-wrap gap-2">
            {cloud.map((skill) => (
              <li class="bg-surface px-3 py-1.5 rounded-md text-sm text-text-main border border-border">{skill}</li>
            ))}
          </ul>
        </div>

      </div>
    </div>

  </div>

  <Footer slot="footer" />
</BaseLayout>
