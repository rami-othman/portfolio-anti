---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
---

<BaseLayout title="Rami | AI & Data Engineer" description="Portfolio of Rami, showcasing AI and Data Engineering projects.">
  <Header slot="header" />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 w-full grow flex flex-col justify-center py-20">
    <section class="max-w-3xl animate-fade-in-up">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-text-main mb-6">
        Building intelligent systems & scalable data pipelines.
      </h1>
      <p class="text-xl text-text-muted mb-8 leading-relaxed">
        Hi, I'm Rami. I'm an <span class="text-primary-400 font-medium">AI Engineer</span> and <span class="text-secondary-400 font-medium">Data Engineer</span> specializing in RAG systems, local LLM tooling, computer vision, and analytics pipelines.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a href="/projects" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-lg transition-colors shadow-lg shadow-primary-900/20">
          View Projects
        </a>
        <a href="/about" class="px-6 py-3 bg-surface-elevated hover:bg-surface border border-border text-text-main font-medium rounded-lg transition-colors">
          About Me
        </a>
      </div>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>
